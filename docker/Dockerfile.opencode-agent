FROM node:22-bookworm-slim

# System dependencies: git for code operations, curl for health checks
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install opencode and Playwright MCP server
RUN npm install -g opencode-ai @playwright/mcp

# Install Playwright Chromium browser with all system dependencies.
# Enables the playwright MCP server for headless browser testing.
RUN npx playwright install-deps chromium \
    && npx playwright install chromium

# Allow git to operate safely on the mounted /workspace volume
RUN git config --global --add safe.directory '*'

COPY docker/opencode-bridge/server.js /usr/local/bin/opencode-bridge.js

EXPOSE 4321

ENV PORT=4321
ENV HOST=0.0.0.0
ENV WORKSPACE=/workspace

CMD ["node", "/usr/local/bin/opencode-bridge.js"]
